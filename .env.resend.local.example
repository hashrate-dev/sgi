# Copiá a .env.resend.local (npm run resend:init). No subas .env.resend.local a git.
#
# Agregá UNA línea sin # (obligatoria para envío real):
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
#
# Opcional (dominio verificado). Si no ponés FROM, el servidor usa onboarding@resend.dev.
# RESEND_FROM_EMAIL=Equipo <hola@tudominio.com>

# Si los avisos no llegan a sales@hashrate.space en prueba, destino explícito (tu inbox o prueba Resend):
# MARKETPLACE_NOTIFY_EMAIL_TO=delivered@resend.dev
