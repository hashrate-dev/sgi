# Copiá a .env.resend.local (npm run resend:init). No subas .env.resend.local a git.
#
# Agregá UNA línea sin # (obligatoria para envío real). La clave sale solo de resend.com (re_…).
# No anteponas re_ a un token de Vercel (vcp_…): eso no funciona (re_vcp_… inválido).
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx
#
# Remitente obligatorio con dominio verificado en Resend (ej. mail.hashrate.space). No usamos onboarding@resend.dev.
# RESEND_FROM_EMAIL=Hashrate Space <noreply@mail.hashrate.space>
#
# Remitente solo del reset (si no está, usa RESEND_FROM_EMAIL). Debe ser @mail.hashrate.space si ese es el dominio verificado.
# PASSWORD_RESET_FROM_EMAIL=Hashrate Space <noreply@mail.hashrate.space>
#
# Si 1/true: producción, relay con error “testing” / remitente (ver código).
# PASSWORD_RESET_RESEND_SANDBOX_RELAY=0
#
# LOCAL (npm run dev): por defecto NO hay relay a sales@. Si querés esa copia de respaldo: PASSWORD_RESET_DEV_RELAY=1
# PASSWORD_RESET_DEV_RELAY=0
#
# Si 1/true: nunca relay a sales (ni local ni Vercel).
# PASSWORD_RESET_DISABLE_RELAY=0
#
# Producción: relay a sales@ SOLO si ponés 1/true aquí (o PASSWORD_RESET_RESEND_SANDBOX_RELAY=1 con error de prueba Resend).
# Por defecto en prod no hay relay: el mail debe llegar a jv@ vía Resend verificado o vía SMTP arriba.
# PASSWORD_RESET_RELAY_ON_FAILURE=0
#
# Para que el reset llegue al MAIL DEL USUARIO (local y Vercel): definí PASSWORD_RESET_SMTP_* (Workspace).
# El servidor intenta SMTP a ese correo ANTES que Resend; así no dependés del relay a sales@.
# Alternativa sin SMTP: dominio verificado en Resend (mail.hashrate.space) + PASSWORD_RESET_FROM_EMAIL / RESEND_FROM_EMAIL con @mail.hashrate.space.
# PASSWORD_RESET_SMTP_HOST=smtp.gmail.com
# PASSWORD_RESET_SMTP_PORT=587
# PASSWORD_RESET_SMTP_SECURE=false
# PASSWORD_RESET_SMTP_USER=tu_cuenta@gmail.com
# PASSWORD_RESET_SMTP_PASS=contraseña_de_aplicación
# PASSWORD_RESET_SMTP_FROM=Hashrate Space <noreply@mail.hashrate.space>

# Si los avisos no llegan a sales@hashrate.space en prueba, destino explícito (tu inbox o prueba Resend):
# MARKETPLACE_NOTIFY_EMAIL_TO=sales@hashrate.space
