NODE_ENV=development
PORT=8080
CORS_ORIGIN=http://localhost:5173

# Optional: SQLite database path (default: data.db). Se ignora si SUPABASE_DATABASE_URL está definida.
# SQLITE_PATH=data.db

# --- Base de usuarios (y resto de datos) en Supabase ---
# La tabla `users` (roles, Cliente tienda, etc.) vive en Postgres del proyecto Supabase.
# Sin esta variable, el servidor usa SQLite local (usuarios distintos a hashrate.space).
#
# Opción A: pegar la URI en server/.env o en la raíz del repo (.env)
# Opción B: npm run supabase:set -- "postgresql://postgres.xxx:PASSWORD@..."
#
# Dashboard: Project Settings → Database → Connection string → URI (pooler 6543 recomendado en serverless).
# Si solo tenés DATABASE_URL de Supabase y apunta a *.supabase.co, el servidor la toma como SUPABASE_DATABASE_URL.
# SUPABASE_DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# JWT para autenticación (en producción usar un valor largo y secreto)
# JWT_SECRET=tu-secreto-muy-largo-y-aleatorio

# Cookie de sesión httpOnly (producción): none = front y API en distintos sitios (ej. sgi → Render); lax si comparten sitio.
# AUTH_COOKIE_SAMESITE=none

# Solo desarrollo: crear usuarios al primer POST /auth/login (JSON en una línea o multilínea escapada). Sin esto no hay seed automático.
# DEV_SEED_USERS_JSON=[{"email":"admin@local.test","password":"cambiar123","role":"admin_a"}]

# Opcional: reemplazar la lista de pools Kryptex (JSON array: url, workers[], usuario, modelo). Si no se define, se usan los defaults del servidor.
# KRYPTEX_POOLS_JSON=

# Render API (opcional): listar servicios y disparar deploy desde la app
# Crear key en https://dashboard.render.com → Account Settings → API Keys
# RENDER_API_KEY=rnd_xxxxxxxxxxxx

# --- WhatsApp Cloud API (Meta): aviso al generar orden del carrito marketplace ---
# Guía de plantilla y pasos: server/docs/WHATSAPP_MARKETPLACE.md
# WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxx...
# WHATSAPP_PHONE_NUMBER_ID=123456789012345 (ID del número en Meta, no el +595...)
# WHATSAPP_NOTIFY_TO=595991907308 (destino del aviso, solo dígitos)
# WHATSAPP_TEMPLATE_NAME=nueva_orden_marketplace
# WHATSAPP_TEMPLATE_LANG=es
# WHATSAPP_GRAPH_VERSION=v21.0

# --- Email transaccional (Resend): aviso automático de nueva orden marketplace ---
# Crear API key en https://resend.com/api-keys
# IMPORTANTE: el remitente debe ser un email/dominio verificado en Resend.
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=Hashrate Space <noreply@mail.hashrate.space>
# MARKETPLACE_NOTIFY_EMAIL_TO=sales@hashrate.space
# MARKETPLACE_CONTACT_EMAIL_TO=sales@hashrate.space
# Entrega directa a sales@ vía Google Workspace (recomendado si Resend no llega al buzón):
# PASSWORD_RESET_SMTP_HOST=smtp.gmail.com
# PASSWORD_RESET_SMTP_PORT=587
# PASSWORD_RESET_SMTP_USER=sales@hashrate.space
# PASSWORD_RESET_SMTP_PASS=contraseña_de_aplicación
# PASSWORD_RESET_SMTP_FROM=Hashrate Space <sales@hashrate.space>
# MARKETPLACE_NOTIFY_SUBJECT_PREFIX=[Marketplace]
# URL del panel de órdenes en los mails (usar apex; no app.hashrate.space)
# MARKETPLACE_QUOTES_PANEL_URL=https://hashrate.space/marketplace/orders
# APP_PUBLIC_URL=https://hashrate.space
