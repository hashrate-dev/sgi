{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "app.hashrate.space" }],
      "destination": "https://hashrate.space/:path*",
      "permanent": true
    },
    { "source": "/marketplace/home", "destination": "/", "permanent": true },
    { "source": "/marketplace", "destination": "/equipment", "permanent": true },
    { "source": "/marketplace/services", "destination": "/services", "permanent": true },
    { "source": "/marketplace/company", "destination": "/company", "permanent": true },
    { "source": "/marketplace/faq", "destination": "/faq", "permanent": true },
    { "source": "/marketplace/contact", "destination": "/contact", "permanent": true },
    { "source": "/marketplace/login", "destination": "/acceso", "permanent": true },
    { "source": "/marketplace/signup", "destination": "/registro", "permanent": true },
    { "source": "/marketplace/registro", "destination": "/registro", "permanent": true }
  ],
  "rewrites": [{"source": "/((?!api/).*)", "destination": "/index.html"}],
  "framework": null,
  "functions": {"api/[[...path]].js": {"maxDuration": 60}},
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ]
}
